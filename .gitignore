# ==================== RESULTS (Selective) ====================

# Large result files (but keep key outputs)
results/experiments/*.csv
results/model_outputs/all_predictions_*.csv

# BUT keep summary tables
!results/tables/summary_*.csv
!results/tables/latex_*.tex

# Keep all figures (they should be small enough)
!results/figures/*.png
!results/figures/*.pdf

# ==================== MISC ====================

# Archives
*.zip
*.tar.gz
*.rar

# Scratch/debug files
scratch/
debug/
test_output/
experiments_old/

# ==================== PROJECT SPECIFIC ====================

# Don't commit large raw video files if you download them
data/videos/
*.mp4
*.avi

# Don't commit intermediate cache
.cache/
cache/

# Keep these important files
!.gitignore
!README.md
!LICENSE
!requirements.txt
!environment.yml

# Add this to your .gitignore
echo "*.pkl" >> .gitignore
echo "*.pptx" >> .gitignore
echo "csv/*.csv" >> .gitignore
echo "pics/*.png" >> .gitignore
echo "key_results/*.png" >> .gitignore
echo "key_results/*.csv" >> .gitignore
echo "instagram/*.png" >> .gitignore
